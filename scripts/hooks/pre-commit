#!/usr/bin/env bash
#
# Pre-commit secret scan via gitleaks.
# Blocks the commit if a hardcoded secret (e.g. a 20i API key) is staged.
#
# Install:  scripts/hooks/install.sh   (or: cp scripts/hooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit)
# Requires: gitleaks  (brew install gitleaks)
#
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root" || exit 0

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks not installed — skipping secret scan." >&2
  echo "    Install it so commits are protected:  brew install gitleaks" >&2
  exit 0
fi

cfg=()
[ -f .gitleaks.toml ] && cfg=(--config .gitleaks.toml)

if ! gitleaks git --staged --redact "${cfg[@]}"; then
  {
    echo ""
    echo "❌ gitleaks detected a potential secret in your STAGED changes — commit aborted."
    echo "   • Remove the secret and load it from an environment variable instead."
    echo "   • False positive? Add an allowlist entry in .gitleaks.toml."
    echo "   • Emergency bypass (NOT recommended): git commit --no-verify"
  } >&2
  exit 1
fi

exit 0
